# Terraform
.terraform/
.terraform.lock.hcl
*.tfplan
*.tfstate
*.tfstate.*

# Claude
# Project skills (.claude/skills/) are committed to the repo so they travel
# with the template; everything else under .claude/ is local machine state.
# find-skills is a symlink into .agents/ (gitignored below), so exclude it
# to avoid committing a dangling link.
.claude/*
!.claude/skills/
.claude/skills/find-skills
.agents/
.claude.json

# OS & Shell
.bash_history
.bash_logout
.bashrc
.cache/
.config/
.gitconfig
.init_done
.profile
.wget-hsts

# Local files
.local/
.npm/
.go/
.zai/
.skills/

# Testing
testing/
my-coder-template/
skills-lock.json
